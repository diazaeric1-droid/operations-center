# notes_watch configuration. Copy to `.env` (git-ignored) and fill in.
# Every value is optional except the Telegram pair (needed for the push).

# --- Telegram (the push) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- where the dated Obsidian note is written ---
# default: ~/.openclaw/workspace/Cowork-Brain/00-Inbox/notes-watch
# NOTES_WATCH_VAULT_INBOX=

# --- "decide when to run" knobs ---
NOTES_WATCH_MIN_NEW=1            # below this many new notes, never alert
NOTES_WATCH_COOLDOWN_HOURS=6     # min hours between alerts (anti-spam)
NOTES_WATCH_SEVERITY=45          # gate severity 0-100 needed to alert

# --- LLM (local `claude` CLI on your Max subscription; no API key) ---
NOTES_WATCH_GATE_MODEL=claude-haiku-4-5-20251001
NOTES_WATCH_SUMMARY_MODEL=claude-sonnet-4-6
NOTES_WATCH_LLM_TIMEOUT=180

# NOTES_WATCH_STANDING_Q=What are the emerging downtime and curtailment risks ...
